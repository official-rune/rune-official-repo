{% comment %} RUNE APPAREL - SKOOP HERO WITH ARROWS + FADE + TEXT SLIDE {% endcomment %}

<div class="rune-hero" id="runeHero">
  <div class="slides-wrapper" id="slidesWrapper">
    {% for block in section.blocks %}
      <div class="slide" data-index="{{ forloop.index0 }}" 
      {% if block.settings.image != blank %}
            style="background-image: url('{{ block.settings.image | image_url: width: 2000 }}');"
            {% endif %}>
        <div class="slide-content">
          <h1>{{ block.settings.heading | escape }}</h1>
          <p>{{ block.settings.subheading | escape }}</p>
          <a href="{{ block.settings.button_link }}" class="hero-btn">{{ block.settings.button_text | escape }}</a>
        </div>
      </div>
    {% endfor %}
  </div>

  <!-- Navigation Arrows -->
  <button class="hero-arrow hero-arrow-left" aria-label="Previous slide">‹</button>
  <button class="hero-arrow hero-arrow-right" aria-label="Next slide">›</button>
</div>

{% schema %}
{
  "name": "Rune Heros",
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 10,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "RUNE APPAREL"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Streetwear that hits different"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link",
          "default": "/collections/all"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Rune Heros",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}